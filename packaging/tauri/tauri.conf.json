{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HackKnow",
  "version": "0.2.0",
  "identifier": "com.hackknow.aios",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "devUrl": "http://localhost:8787",
    "frontendDist": "../../ui"
  },
  "app": {
    "windows": [{
      "title": "HackKnow AI OS",
      "width": 1280,
      "height": 820,
      "minWidth": 960,
      "minHeight": 600,
      "transparent": false,
      "decorations": true,
      "fullscreen": false,
      "resizable": true,
      "url": "http://localhost:8787"
    }],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "Productivity",
    "shortDescription": "JARVIS-style autonomous AI operating system",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all"
  }
}
