# =========================================
# HackKnow AI OS — environment variables
# Copy to .env and fill in the keys you have
# =========================================

# --- Identity ---
HACKKNOW_USER_NAME=Myth
HACKKNOW_ASSISTANT_NAME=Yahavi
HACKKNOW_ASSISTANT_MODE=jarvis           # jarvis | neutral | playful
HACKKNOW_DEFAULT_LANG=auto               # auto | en | hi

# --- LLM providers (any subset works — vault picks fresh keys per call) ---
GROQ_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
COHERE_API_KEY=
MISTRAL_API_KEY=
TOGETHER_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
PERPLEXITY_API_KEY=
HUGGINGFACE_API_KEY=

# --- Local LLM (zero-key fallback) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# --- Realtime search providers ---
TAVILY_API_KEY=
EXA_API_KEY=
SERPER_API_KEY=
BRAVE_API_KEY=
FIRECRAWL_API_KEY=
JINA_API_KEY=

# --- GitHub (for repo skill) ---
GITHUB_TOKEN=

# --- Voice ---
WHISPER_MODEL=base                       # tiny | base | small | medium
KOKORO_VOICE_EN=af_bella
KOKORO_VOICE_HI=hf_alpha

# --- Browser ---
PLAYWRIGHT_HEADLESS=true

# --- Ecommerce ---
WC_BASE_URL=https://shop.hackknow.com
WC_CONSUMER_KEY=
WC_CONSUMER_SECRET=
MEDUSA_BASE_URL=http://localhost:9000
MEDUSA_API_KEY=

# --- Content + workflow ---
COMFYUI_BASE_URL=http://localhost:8188
FLOWISE_BASE_URL=http://localhost:3000
FLOWISE_API_KEY=

# --- Server ---
HACKKNOW_HOST=0.0.0.0
HACKKNOW_PORT=8787
HACKKNOW_LOG_LEVEL=INFO
